# Supabase
NEXT_PUBLIC_SUPABASE_URL=your-supabase-url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Kakao OAuth (Supabase Auth Provider에서 설정)
# NEXT_PUBLIC_KAKAO_CLIENT_ID는 Supabase 대시보드에서 관리

# Solapi SMS/알림톡 API (Supabase Edge Function 환경변수 — supabase secrets set)
# SMS_API_KEY=NCSA...
# SMS_API_SECRET=your-solapi-api-secret
# SMS_SENDER_PHONE=0621234567        # 사전 등록된 발신번호
# KAKAO_CHANNEL_ID=_execQn           # 카카오 채널 pfId (알림톡용)
# ADMIN_PHONE=01012345678            # 상담 알림 수신 번호

# ISR Revalidate
REVALIDATE_SECRET=your-revalidate-secret

# Site URL
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Meta Pixel (데이터 세트) / Conversions API
# NEXT_PUBLIC_META_PIXEL_ID=your-dataset-id
# META_CAPI_ACCESS_TOKEN=your-capi-access-token
# META_CAPI_TEST_EVENT_CODE=TEST12345  # 이벤트 매니저 검증용. 운영 전에 제거

# E2E 테스트 계정 (Playwright)
# TEST_ADMIN_USERNAME=admin
# TEST_ADMIN_PASSWORD=your-admin-password
# TEST_MENTOR_USERNAME=mentor
# TEST_MENTOR_PASSWORD=your-mentor-password
# TEST_ASSISTANT_USERNAME=assistant
# TEST_ASSISTANT_PASSWORD=your-assistant-password
